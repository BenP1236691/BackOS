{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/site/:id", "destination": "/api/site" },
    { "source": "/((?!api|site).*)", "destination": "/index.html" }
  ]
}
